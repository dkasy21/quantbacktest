# Database — the current prisma/schema.prisma targets Postgres (Neon via
# Vercel), NOT SQLite. Set this to your Neon/Postgres connection string.
# (DATABASE_URL below is only relevant if you point schema.prisma back at
# SQLite for local dev.)
POSTGRES_PRISMA_URL="postgres://user:password@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Market data provider. "yahoo" works with zero setup but is NOT licensed for
# commercial use (see README) — set to "twelvedata" + TWELVE_DATA_API_KEY
# before you accept payment from real customers.
DATA_PROVIDER="yahoo"
TWELVE_DATA_API_KEY=""
# Optional secondary data provider used by lib/data/polygonData.ts.
POLYGON_API_KEY=""
# Licensed CME futures data (ES, MNQ, GC, CL, etc.) — see lib/data/databentoData.ts.
# Get a key + $125 free credit at https://databento.com. Without this, futures
# symbols fall back to TwelveData's cash-index substitute or unlicensed Yahoo data.
DATABENTO_API_KEY=""

# Crypto pairs (BTC, ETH, SOL, or any Binance pair like BTCUSDT) are served by
# Binance's free public market data API — no key needed, nothing to set here.
# See lib/data/binanceData.ts. This is also the source of the orderflow
# signals (of_delta, of_cvd, of_buy_ratio, of_delta_divergence_*) — Binance's
# candle data includes a real taker buy/sell volume split, which the other
# providers above don't expose.

# Required for the AI strategy parser (app/api/ai-strategy/route.ts).
# Without this, "Analyse & Backtest with AI" fails with a 500.
GROQ_API_KEY=""

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (use TEST keys until you're ready to go live)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_ID_PRO="price_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
