# Database (SQLite for local dev; swap to Postgres connection string in production)
DATABASE_URL="file:./dev.db"

# Market data provider. "yahoo" works with zero setup but is NOT licensed for
# commercial use (see README) — set to "twelvedata" + TWELVE_DATA_API_KEY
# before you accept payment from real customers.
DATA_PROVIDER="yahoo"
TWELVE_DATA_API_KEY=""

# Licensed CME futures data (ES, MNQ, GC, CL, etc.) — see lib/data/databentoData.ts.
# Get a key + $125 free credit at https://databento.com. Without this, futures
# symbols fall back to TwelveData's cash-index substitute or unlicensed Yahoo data.
DATABENTO_API_KEY=""

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (use TEST keys until you're ready to go live)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_ID_PRO="price_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
